# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.
#
# Docker Compose reads `.env` automatically from the project root
# and substitutes ${VAR} references in docker-compose.yml.

# ─── Postgres ─────────────────────────────────────────────
POSTGRES_USER=quizmemo
POSTGRES_PASSWORD=change-me-dev-only
POSTGRES_DB=quizmemo

# ─── JWT (backend-issued tokens) ──────────────────────────
# Must be at least 32 characters for HS256.
JWT_KEY=change-me-at-least-32-chars-long-random!!
JWT_ISSUER=quizmemo

# ─── Google Sign-In ───────────────────────────────────────
# Web OAuth Client ID from Google Cloud Console.
# This must match `WEB_CLIENT_ID` in android/.../auth/GoogleAuth.kt.
GOOGLE_CLIENT_ID=REPLACE-WITH-WEB-OAUTH-CLIENT-ID.apps.googleusercontent.com
